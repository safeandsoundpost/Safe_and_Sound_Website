{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "safe-and-sound-website",
    "compatibility_date": "2026-06-03",
    "observability": {
        "enabled": true
    },
    "assets": {
        "directory": "./dist",
        "not_found_handling": "single-page-application"
    }
}
